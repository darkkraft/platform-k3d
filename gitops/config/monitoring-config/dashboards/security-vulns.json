      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (namespace, image_repository, image_tag, severity) (trivy_image_vulnerabilities) > 0",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true }, "renameByName": { "Value": "count", "image_repository": "image", "image_tag": "tag" } } },
        { "id": "sortBy", "options": { "fields": "", "sort": [{ "field": "count", "desc": true }] } }
      ]
    },
    {
      "id": 7,
      "title": "Total vulnerabilities by severity (trend)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum by (severity) (trivy_image_vulnerabilities)", "legendFormat": "{{severity}}" }
